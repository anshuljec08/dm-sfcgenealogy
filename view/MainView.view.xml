<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    controllerName="sap.dm.custom.plugin.sfcGenealogy.controller.MainView"
    height="100%">

    <Panel class="sapUiSmallMargin sfcGenealogyCard" height="100%">
        <!-- Panel Header -->
        <headerToolbar>
            <Toolbar class="sfcGenealogyHeader">
                <core:Icon src="sap-icon://tree" class="sapUiSmallMarginEnd" />
                <Title text="{i18n>pluginTitle}" />
                <ToolbarSpacer />
                <ObjectStatus 
                    text="{= ${genealogy>/sfc} ? 'SFC: ' + ${genealogy>/sfc} : 'Select an SFC'}"
                    state="Information" />
                <ObjectNumber 
                    number="{genealogy>/totalComponents}" 
                    unit="components"
                    visible="{genealogy>/hasData}" />
            </Toolbar>
        </headerToolbar>

        <!-- Panel Content -->
        <content>
            <VBox height="100%" class="sapUiNoMargin">
                
                <!-- Toolbar -->
                <Toolbar class="sfcGenealogyToolbar">
                    <SearchField
                        id="searchField"
                        placeholder="{i18n>searchPlaceholder}"
                        width="15rem"
                        liveChange="onFilterChange"
                        class="sapUiTinyMarginEnd" />
                    
                    <ToolbarSpacer />
                    
                    <Label text="{i18n>lastRefresh}:" class="sapUiTinyMarginEnd" />
                    <Text text="{genealogy>/lastRefresh}" class="sapUiTinyMarginEnd" />
                    
                    <ToolbarSeparator />
                    
                    <Button
                        icon="sap-icon://excel-attachment"
                        tooltip="{i18n>export}"
                        press="onExportPress"
                        type="Transparent"
                        enabled="{genealogy>/hasData}" />
                    <Button
                        icon="sap-icon://refresh"
                        tooltip="{i18n>refresh}"
                        press="onRefreshPress"
                        type="Transparent" />
                    <Button
                        id="closeButton"
                        icon="sap-icon://decline"
                        tooltip="{i18n>close}"
                        press="onClosePress"
                        type="Transparent"
                        visible="false" />
                </Toolbar>

                <!-- Loading Indicator -->
                <FlexBox
                    visible="{genealogy>/isLoading}"
                    height="200px"
                    alignItems="Center"
                    justifyContent="Center">
                    <BusyIndicator />
                </FlexBox>

                <!-- No Data Message -->
                <FlexBox
                    visible="{= !${genealogy>/isLoading} &amp;&amp; !${genealogy>/hasData} &amp;&amp; !${genealogy>/sfc}}"
                    height="100%"
                    direction="Column"
                    alignItems="Center"
                    justifyContent="Center"
                    class="sfcGenealogyNoData">
                    <core:Icon
                        src="sap-icon://product"
                        size="4rem"
                        color="#bfbfbf"
                        class="sapUiMediumMarginBottom" />
                    <Title text="{i18n>noSfcSelected}" level="H3" titleStyle="H4" />
                    <Text text="{i18n>noSfcSelectedDescription}" class="sapUiSmallMarginTop" />
                </FlexBox>

                <!-- No Components Message -->
                <FlexBox
                    visible="{= !${genealogy>/isLoading} &amp;&amp; !${genealogy>/hasData} &amp;&amp; !!${genealogy>/sfc}}"
                    height="100%"
                    direction="Column"
                    alignItems="Center"
                    justifyContent="Center"
                    class="sfcGenealogyNoData">
                    <core:Icon
                        src="sap-icon://inventory"
                        size="4rem"
                        color="#bfbfbf"
                        class="sapUiMediumMarginBottom" />
                    <Title text="{i18n>noComponentsFound}" level="H3" titleStyle="H4" />
                    <Text text="{i18n>noComponentsFoundDescription}" class="sapUiSmallMarginTop" />
                </FlexBox>

                <!-- Tree View for Hierarchical Display -->
                <Panel
                    visible="{= !${genealogy>/isLoading} &amp;&amp; ${genealogy>/hasData}}"
                    class="sfcGenealogyTreePanel sapUiSmallMarginTop sapUiSmallMarginBeginEnd"
                    expandable="true"
                    expanded="true">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Component Hierarchy" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <List
                            id="componentsList"
                            items="{genealogy>/components}"
                            class="sfcGenealogyTree">
                            <CustomListItem type="Active" press="onComponentRowPress">
                                <HBox alignItems="Center" class="sapUiSmallMarginBeginEnd sapUiTinyMarginTopBottom">
                                    <core:Icon src="sap-icon://inventory" class="sapUiSmallMarginEnd" color="#27ae60" />
                                    <VBox>
                                        <Text text="{genealogy>component} - {genealogy>description}" class="sfcGenealogyComponentName" />
                                        <HBox class="sapUiTinyMarginTop">
                                            <Text text="Qty: {genealogy>quantityAssembled} {genealogy>unitOfMeasure}" class="sapUiTinyMarginEnd" />
                                            <Text text="| Batch: {genealogy>batchNumber}" visible="{= !!${genealogy>batchNumber}}" />
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>

                <!-- Summary Panel -->
                <Panel
                    visible="{= !${genealogy>/isLoading} &amp;&amp; ${genealogy>/hasData}}"
                    class="sfcGenealogySummaryPanel sapUiSmallMarginTop"
                    expandable="true"
                    expanded="true">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="{i18n>componentsSummary}" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <Table
                            id="componentsTable"
                            items="{genealogy>/components}"
                            mode="SingleSelectMaster"
                            growing="true"
                            growingThreshold="50"
                            alternateRowColors="true"
                            class="sfcGenealogyTable">
                            <columns>
                                <Column width="3rem" hAlign="Center">
                                    <Text text="#" />
                                </Column>
                                <Column width="12rem">
                                    <Text text="{i18n>component}" />
                                </Column>
                                <Column width="15rem" minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="{i18n>description}" />
                                </Column>
                                <Column width="8rem" minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="{i18n>operation}" />
                                </Column>
                                <Column width="6rem" hAlign="End">
                                    <Text text="{i18n>quantity}" />
                                </Column>
                                <Column width="5rem" hAlign="Center" minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="{i18n>uom}" />
                                </Column>
                                <Column width="10rem" minScreenWidth="Desktop" demandPopin="true">
                                    <Text text="{i18n>batchNumber}" />
                                </Column>
                                <Column width="10rem" minScreenWidth="Desktop" demandPopin="true">
                                    <Text text="Serial Number" />
                                </Column>
                                <Column width="5rem" hAlign="Center" minScreenWidth="Desktop" demandPopin="true">
                                    <Text text="{i18n>dataFields}" />
                                </Column>
                                <Column width="14rem" minScreenWidth="Desktop" demandPopin="true">
                                    <Text text="{i18n>assembledDateTime}" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem type="Navigation" press="onComponentRowPress">
                                    <cells>
                                        <ObjectNumber
                                            number="{genealogy>id}"
                                            state="Information" />
                                        <VBox>
                                            <Text text="{genealogy>component}" class="sfcGenealogyComponentName" />
                                            <Text text="{genealogy>componentVersion}" class="sapUiTinyMarginTop sfcGenealogyVersion" />
                                        </VBox>
                                        <Text text="{genealogy>description}" wrapping="true" />
                                        <Text text="{genealogy>operation}" />
                                        <ObjectNumber
                                            number="{genealogy>quantityAssembled}"
                                            emphasized="true"
                                            state="Success" />
                                        <Text text="{genealogy>unitOfMeasure}" />
                                        <Text text="{genealogy>batchNumber}" />
                                        <Text text="{genealogy>serialNumber}" />
                                        <Button
                                            text="{genealogy>dataFieldsCount}"
                                            icon="sap-icon://tag"
                                            type="Transparent"
                                            press="onDataFieldsPress"
                                            enabled="{= ${genealogy>dataFieldsCount} > 0 }" />
                                        <Text text="{genealogy>assembledDateTime}" wrapping="false" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </content>
                </Panel>

                <!-- Visual Hierarchy Chart -->
                <Panel
                    visible="{= !${genealogy>/isLoading} &amp;&amp; ${genealogy>/hasData}}"
                    class="sfcGenealogyChartPanel sapUiSmallMarginTop"
                    expandable="true"
                    expanded="false">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Visual Hierarchy" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <VBox class="sapUiSmallMargin">
                            <FlexBox 
                                id="visualHierarchyChart"
                                direction="Column" 
                                alignItems="Center"
                                class="sfcGenealogyVisualChart">
                                <!-- Chart is built dynamically in controller -->
                            </FlexBox>
                        </VBox>
                    </content>
                </Panel>
            </VBox>
        </content>
    </Panel>
</mvc:View>
